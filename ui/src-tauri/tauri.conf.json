{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "clarus demo",
  "version": "0.1.0",
  "identifier": "io.edgesentry.clarus-demo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "clarus — Physics Safety Demo",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
