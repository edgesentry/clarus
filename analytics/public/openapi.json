{
  "openapi": "3.1.0",
  "info": {
    "title": "Clarus Verification API",
    "version": "2.0.0",
    "description": "B2B endpoints for verifying BCA Green Mark compliance attestations generated by the clarus edge daemon.\n\nCompliance results (cert_level, EUI, COP, LPD) are read directly from the top-level `attestation` field written on every BCA cycle — no ZKP knowledge required. Third parties (BCA auditors, banks, tenants) use these endpoints to independently verify compliance claims without accessing raw sensor data.\n\n**BCA default path** (`framework: none`): compliance result read from `record.attestation`. `proof_verified` is `null` — tamper-evidence is provided by the WORM storage and Ed25519 signature chain.\n\n**Future B2B path** (`framework: sp1`): SP1 ZKP proof of computational correctness, tracked in [edgesentry-rs#387](https://github.com/edgesentry/edgesentry-rs/issues/387)."
  },
  "servers": [
    { "url": "https://clarus.edgesentry.io", "description": "Production" }
  ],
  "paths": {
    "/api/verify": {
      "get": {
        "operationId": "verifyAttestation",
        "summary": "Verify BCA Green Mark attestation",
        "description": "Returns the BCA Green Mark compliance attestation for a site.\n\nReads the top-level `attestation` field written by the clarus edge daemon on every BCA cycle. Falls back to `zk_proof.public_values` for records written before clarus v2 (legacy path).",
        "tags": ["Verification"],
        "parameters": [
          {
            "name": "site",
            "in": "query",
            "required": true,
            "description": "Site ID (e.g. MCH-OUTLET-042)",
            "schema": { "type": "string", "example": "MCH-OUTLET-042" }
          }
        ],
        "responses": {
          "200": {
            "description": "Attestation found — valid or invalid",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/VerifyResponseValid" },
                    { "$ref": "#/components/schemas/VerifyResponseInvalid" }
                  ]
                },
                "examples": {
                  "q1_gold": {
                    "summary": "Q1 — Gold, all criteria pass (BCA default path)",
                    "value": {
                      "valid": true,
                      "site_id": "MCH-OUTLET-042",
                      "cert_level": "gold",
                      "all_criteria_pass": true,
                      "cop_pass": true,
                      "lpd_pass": true,
                      "eui_kwh_m2": 105.0,
                      "framework": "none",
                      "proof_verified": null,
                      "attested_at_ms": 1778000000000,
                      "record_hash": "3f2a1b...",
                      "verify_url": "https://clarus.edgesentry.io/api/verify?site=MCH-OUTLET-042"
                    }
                  },
                  "q2_not_certified": {
                    "summary": "Q2 — Not Certified (fails BCA thresholds, honest report)",
                    "value": {
                      "valid": true,
                      "site_id": "BLD-HIGHUSE-FAIL",
                      "cert_level": "not_certified",
                      "all_criteria_pass": false,
                      "cop_pass": false,
                      "lpd_pass": true,
                      "eui_kwh_m2": 155.0,
                      "framework": "none",
                      "proof_verified": null,
                      "attested_at_ms": 1778000000000,
                      "record_hash": "9c4d2e...",
                      "verify_url": "https://clarus.edgesentry.io/api/verify?site=BLD-HIGHUSE-FAIL"
                    }
                  },
                  "q3_tampered": {
                    "summary": "Q3 — Tampered legacy record (fraud attempt)",
                    "value": {
                      "valid": false,
                      "site_id": "BLD-TAMPER-PASS",
                      "reason": "proof_bytes_do_not_match_public_values",
                      "framework": "mock",
                      "record_hash": "7a1f9b..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing `site` parameter",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "site parameter required" }
              }
            }
          },
          "404": {
            "description": "No record found for the given site",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerifyResponseInvalid" },
                "example": { "valid": false, "site_id": "UNKNOWN-SITE", "reason": "no_record" }
              }
            }
          }
        }
      }
    },
    "/api/verify/raw": {
      "get": {
        "operationId": "verifyRaw",
        "summary": "Fetch raw ZkProof envelope",
        "description": "Returns the raw `ZkProof` envelope for independent client-side verification. Use for B2B system integration where the caller runs their own verification logic.\n\nNote: only available for sites with legacy `zk_proof` records. BCA default-path records (`framework: none`) do not include a ZkProof envelope.",
        "tags": ["Verification"],
        "parameters": [
          {
            "name": "site",
            "in": "query",
            "required": true,
            "description": "Site ID (e.g. MCH-OUTLET-042)",
            "schema": { "type": "string", "example": "MCH-OUTLET-042" }
          }
        ],
        "responses": {
          "200": {
            "description": "Raw proof envelope",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerifyRawResponse" },
                "example": {
                  "site_id": "MCH-OUTLET-042",
                  "framework": "mock",
                  "program_id": "bca-green-mark-2021-v1-mock",
                  "proof_bytes": "base64...",
                  "public_values": "base64...",
                  "record_hash": "3f2a1b...",
                  "attested_at_ms": 1778000000000,
                  "fetched_at_ms": 1778000001000
                }
              }
            }
          },
          "400": {
            "description": "Missing `site` parameter",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "No ZkProof record found for the given site",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "no_zkp_record", "site_id": "UNKNOWN-SITE" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Framework": {
        "type": "string",
        "enum": ["none", "mock", "sp1", "risc0"],
        "description": "`none` = BCA default path, attestation read directly from WORM record (no ZKP). `mock` = legacy BLAKE3(public_values) proof. `sp1`/`risc0` = future ZKP path for green finance B2B."
      },
      "CertLevel": {
        "type": "string",
        "enum": ["platinum", "gold_plus", "gold", "certified", "not_certified"],
        "description": "BCA Green Mark 2021 certification level (existing buildings, Section 4)."
      },
      "VerifyResponseValid": {
        "type": "object",
        "required": ["valid", "site_id", "cert_level", "all_criteria_pass", "cop_pass", "lpd_pass", "eui_kwh_m2", "framework", "attested_at_ms", "verify_url"],
        "properties": {
          "valid":             { "type": "boolean", "enum": [true] },
          "site_id":           { "type": "string" },
          "cert_level":        { "$ref": "#/components/schemas/CertLevel" },
          "all_criteria_pass": { "type": "boolean", "description": "True when EUI, COP, and LPD all pass BCA thresholds." },
          "cop_pass":          { "type": "boolean", "description": "Chiller COP ≥ 0.65 (SS 553:2016)." },
          "lpd_pass":          { "type": "boolean", "description": "Lighting power density ≤ 15 W/m²." },
          "eui_kwh_m2":        { "type": "number", "description": "Annual energy use intensity (kWh/m²/year)." },
          "framework":         { "$ref": "#/components/schemas/Framework" },
          "proof_verified":    { "type": ["boolean", "null"], "description": "`null` for BCA default path (`framework: none`). `true`/`false` for legacy mock path. Future SP1 path TBD." },
          "attested_at_ms":    { "type": "integer", "description": "Unix timestamp (ms) of the attested audit record." },
          "record_hash":       { "type": ["string", "null"], "description": "BLAKE3 hash of the AuditRecord (hex)." },
          "verify_url":        { "type": "string", "format": "uri", "description": "Canonical URL of this verification result." }
        }
      },
      "VerifyResponseInvalid": {
        "type": "object",
        "required": ["valid", "site_id", "reason"],
        "properties": {
          "valid":       { "type": "boolean", "enum": [false] },
          "site_id":     { "type": "string" },
          "reason": {
            "type": "string",
            "enum": [
              "no_record",
              "no_attestation",
              "public_values_decode_failed",
              "proof_bytes_do_not_match_public_values"
            ],
            "description": "`no_record` = no audit record found. `proof_bytes_do_not_match_public_values` = tampered legacy record."
          },
          "framework":   { "$ref": "#/components/schemas/Framework" },
          "record_hash": { "type": ["string", "null"] }
        }
      },
      "VerifyRawResponse": {
        "type": "object",
        "required": ["site_id", "framework", "program_id", "proof_bytes", "public_values", "attested_at_ms", "fetched_at_ms"],
        "properties": {
          "site_id":        { "type": "string" },
          "framework":      { "$ref": "#/components/schemas/Framework" },
          "program_id":     { "type": "string" },
          "proof_bytes":    { "type": "string", "description": "Base64-encoded proof bytes. For mock: BLAKE3(public_values_bytes)." },
          "public_values":  { "type": "string", "description": "Base64-encoded JSON of GreenMarkAttestation." },
          "record_hash":    { "type": ["string", "null"] },
          "attested_at_ms": { "type": "integer" },
          "fetched_at_ms":  { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error":   { "type": "string" },
          "site_id": { "type": "string" }
        }
      }
    }
  }
}
