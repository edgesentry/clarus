# ── Site ──────────────────────────────────────────────────────────────────────
SITE_ID=site_sgp_001
PROFILE=sg-maritime-security          # matches clarus/profiles/{PROFILE}/

# ── Storage backend ───────────────────────────────────────────────────────────
# Set to "r2" for Cloudflare R2, "minio" for local MinIO
STORAGE_BACKEND=minio

# MinIO (local — start with: docker run -p 9000:9000 minio/minio server /data)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Cloudflare R2 (use R2 API tokens from Cloudflare dashboard)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Buckets ───────────────────────────────────────────────────────────────────
# AUDIT_BUCKET:     WORM/Object Lock enabled — stores full signed audit chain
# ANALYTICS_BUCKET: Standard — stores heartbeats + alerts for analytics app
AUDIT_BUCKET=clarus-audit
ANALYTICS_BUCKET=clarus-public

# ── Paths ─────────────────────────────────────────────────────────────────────
EDS_BIN=../../edgesentry-rs/target/debug/eds
PROFILES_DIR=../profiles

# ── Timing ────────────────────────────────────────────────────────────────────
CYCLE_INTERVAL=2          # seconds between sim cycles
HEARTBEAT_INTERVAL=30     # seconds between heartbeat uploads
